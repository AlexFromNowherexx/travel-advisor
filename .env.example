TTS_MEDIA_TYPE=audio/wav
TTS_FILENAME=reply.wav
TTS_CACHE_TTL=0
TTS_ENABLE_CACHE=false
TTS_ENGINE_TIMEOUT=30
TTS_DEBUG=false
