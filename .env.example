AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://agent-foundry-65.cognitiveservices.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-12-01-preview
SERPAPI_API_KEY=
SERPAPI_LIMIT=5
API_BASE_URL=http://localhost:8000
TTS_ENGINE=pyttsx3
TTS_VOICE=
TTS_RATE=180
TTS_VOLUME=1.0
TTS_OUTPUT_DIR=
